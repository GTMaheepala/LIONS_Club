# Copy to `.env` in this folder (`backend/.env`)

MONGO_URI=mongodb+srv://USER:PASS@CLUSTER.mongodb.net/lcms?retryWrites=true&w=majority
# Required for /login, /register, and Bearer tokens — use a long random value locally and in prod.
JWT_SECRET=change-me-to-a-long-random-string
PORT=5000

# Bootstrap super-admin (synced at startup — change password here and restart)
SUPERADMIN_EMAIL=superadmin@gmail.com
SUPERADMIN_PASSWORD=superadmin@123

# Comma-separated origins, or omit for permissive dev (see src/app.js)
# CORS_ORIGIN=http://localhost:3000,https://your-app.vercel.app
